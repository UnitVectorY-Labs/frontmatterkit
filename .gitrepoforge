name: frontmatterkit
default_branch: main
config:
  description: "A Unix-style CLI for validating, querying, asserting, and minimally updating front matter in Markdown files."
  license: MIT
  language: go
  release: release-go
  justfile: true
  release_github: true
  docs:
    enabled: true
    domain: frontmatterkit.unitvectorylabs.com
